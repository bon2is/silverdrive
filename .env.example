# ────────────────────────────────────────────────────────────────
# Google AdMob 설정 (Android/iOS 앱 전용)
# 1. https://admob.google.com 에서 앱 등록 (스토어 미등록 선택 가능)
# 2. 앱 ID와 광고 단위 ID를 아래에 입력하세요
# 3. android/app/src/main/AndroidManifest.xml 에도 App ID 별도 입력 필요
# ────────────────────────────────────────────────────────────────

# AdMob 앱 ID - 예: ca-app-pub-XXXX~YYYY
NEXT_PUBLIC_ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# 배너 광고 단위 ID (테스트 허브·결과 페이지 하단 배너)
NEXT_PUBLIC_ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# 전면(인터스티셜) 광고 단위 ID (테스트 완료 후 1회 노출)
NEXT_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# 개발 중에는 Google 공식 테스트 ID가 자동 사용됩니다 (NODE_ENV=development)

# ────────────────────────────────────────────────────────────────
# Google AdSense 설정
# 1. https://adsense.google.com 에서 계정 생성 후 사이트 등록
# 2. 승인 후 Publisher ID와 Ad Slot ID를 아래에 입력하세요

# Publisher ID (필수) - 예: ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Ad Slot ID (선택) - 광고 단위 생성 후 발급. 없으면 Auto Ads 사용
NEXT_PUBLIC_ADSENSE_SLOT=XXXXXXXXXX

# ────────────────────────────────────────────────────────────────
# Kakao JavaScript SDK 설정 (카카오톡 공유 기능)
# 1. https://developers.kakao.com 에서 앱 생성
# 2. '플랫폼 > 사이트 도메인' 에 https://silverdrive.andxo.com 등록
# 3. '앱 키 > JavaScript 키' 복사 후 아래에 입력
# 키가 없으면 Web Share API / 클립보드 복사로 자동 폴백됩니다
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_JS_APP_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ────────────────────────────────────────────────────────────────
# 검색엔진 인증 코드 (SEO)
# ────────────────────────────────────────────────────────────────

# Google Search Console
# 1. https://search.google.com/search-console 에서 사이트 등록
# 2. 인증 방법: "HTML 태그" 선택 → content="" 안의 값만 복사
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 네이버 서치어드바이저
# 1. https://searchadvisor.naver.com 에서 사이트 등록
# 2. 인증 방법: "HTML 태그" 선택 → content="" 안의 값만 복사
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
