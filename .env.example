# Google AdSense 설정
# 1. https://adsense.google.com 에서 계정 생성 후 사이트 등록
# 2. 승인 후 Publisher ID와 Ad Slot ID를 아래에 입력하세요

# Publisher ID (필수) - 예: ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Ad Slot ID (선택) - 광고 단위 생성 후 발급. 없으면 Auto Ads 사용
NEXT_PUBLIC_ADSENSE_SLOT=XXXXXXXXXX

# ────────────────────────────────────────────────────────────────
# Kakao JavaScript SDK 설정 (카카오톡 공유 기능)
# 1. https://developers.kakao.com 에서 앱 생성
# 2. '플랫폼 > 사이트 도메인' 에 https://silverdrive.andxo.com 등록
# 3. '앱 키 > JavaScript 키' 복사 후 아래에 입력
# 키가 없으면 Web Share API / 클립보드 복사로 자동 폴백됩니다
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_JS_APP_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
